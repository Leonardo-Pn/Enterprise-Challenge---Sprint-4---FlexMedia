# Variáveis globais para o modelo
model = None
vectorizer = None

def init_database():
    """Inicializa o banco de dados SQLite"""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # Tabela de interações
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS interacoes (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp TEXT,
            tipo TEXT,
            entrada TEXT,
            saida_ia TEXT,
            duracao INTEGER,
            session_id TEXT,
            imagem_path TEXT
        )
    ''')
    
    # Tabela de métricas agregadas
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS metricas_diarias (
            data TEXT PRIMARY KEY,
            total_interacoes INTEGER,
                interacoes_texto INTEGER,
            interacoes_imagem INTEGER,
            interacoes_botao INTEGER,
            sentimento_positivo INTEGER,
            sentimento_curioso INTEGER,
            sentimento_negativo INTEGER
        )
    ''')
    
    conn.commit()
    conn.close()
    print("✅ Banco de dados inicializado")

def load_ai_model():
    """Carrega o modelo de IA treinado"""
    global model, vectorizer
    try:
        if MODEL_PATH.exists():
            with open(MODEL_PATH, 'rb') as f:
                model, vectorizer = pickle.load(f)
            print("✅ Modelo de IA carregado com sucesso!")
            return True
        else:
            print("⚠️ Modelo não encontrado. Execute train_model.py primeiro")
            return False
    except Exception as e:
        print(f"❌ Erro ao carregar modelo: {e}")
        return False

def analyze_sentiment(text):
    """Classifica sentimento do texto usando IA"""
    if model and vectorizer:
        try:
            X = vectorizer.transform([text])
            prediction = model.predict(X)[0]
            confidence = max(model.predict_proba(X)[0])
            return prediction, confidence
        except:
            pass
    
    # Fallback baseado em palavras-chave
    text_lower = text.lower()
    palavras_positivas = ['ador', 'legal', 'incr', 'gost', 'fantást', 'marav', 'ótimo', 'excelente']
    palavras_curiosas = ['como', 'o que', 'explique', 'curios', 'por que', 'qual', 'quando']
    palavras_negativas = ['ruim', 'chato', 'entedi', 'não gost', 'poderia melhor', 'fraco']
    
    if any(p in text_lower for p in palavras_positivas):
        return "Positivo", 0.75
    elif any(p in text_lower for p in palavras_curiosas):
        return "Curioso", 0.70
    elif any(p in text_lower for p in palavras_negativas):
        return "Negativo", 0.65
    return "Neutro", 0.50

def analyze_image(image_data):
    """Analisa imagem usando técnicas de visão computacional"""
    try:
        # Decodificar imagem base64
        if ',' in image_data:
            image_data = image_data.split(',')[1]
        image_bytes = base64.b64decode(image_data)
        image = Image.open(io.BytesIO(image_bytes))
        
        # Simular análise (em produção usaria OpenCV real)
        width, height = image.size
        format_name = image.format or 'JPEG'
        
        # Análise simulada baseada no tamanho e características
        if width > 2000:
            resolution = "Alta resolução"
        elif width > 1000:
            resolution = "Média resolução"
        else:
            resolution = "Baixa resolução"
        
        # Simular detecção de pessoas
        import random
        num_pessoas = random.randint(1, 5)
        
        if num_pessoas == 1:
            composicao = "visitante sozinho"
        elif num_pessoas <= 3:
            composicao = "pequeno grupo"
        else:
            composicao = "grupo numeroso"
        
        # Simular expressão dominante
        expressoes = ["curiosidade", "alegria", "neutralidade", "surpresa"]
        expressao = random.choice(expressoes)
        
        resultado = {
            "formato": format_name,
            "resolucao": resolution,
            "dimensoes": f"{width}x{height}",
            "pessoas_detectadas": num_pessoas,
            "composicao": composicao,
            "expressao_dominante": expressao,
            "recomendacao": self.generate_recommendation(composicao, expressao)
        }
        
        return resultado
    
    except Exception as e:
        return {"erro": str(e), "recomendacao": "Não foi possível analisar a imagem"}

def generate_recommendation(composicao, expressao):
    """Gera recomendações baseadas na análise visual"""
    if composicao == "visitante sozinho":
        if expressao == "curiosidade":
            return "Recomendo conteúdo interativo detalhado sobre a obra"
        elif expressao == "alegria":
            return "Sugiro compartilhar esta experiência nas redes sociais"
        else:
            return "Que tal explorar a linha do tempo interativa?"
    elif composicao == "pequeno grupo":
        return "Experiência colaborativa disponível! Toquem juntos na tela"
    else:
        return "Área de grupo ativada! Conteúdo expandido para múltiplos visitantes"

